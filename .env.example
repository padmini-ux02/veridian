# Database
DATABASE_URL=postgresql://veridian:veridian_secret@db:5432/veridian_db
POSTGRES_USER=veridian
POSTGRES_PASSWORD=veridian_secret
POSTGRES_DB=veridian_db

# JWT
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App
APP_NAME=Veridian
APP_VERSION=1.0.0
DEBUG=false
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# AI Model paths
MODEL_DIR=./models
SMS_MODEL_PATH=./models/sms_model.pkl
EMAIL_MODEL_PATH=./models/email_model.pkl
URL_MODEL_PATH=./models/url_model.pkl

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
